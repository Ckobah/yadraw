{
  "name": "yadraw",
  "version": "0.1.0",
  "private": true,
  "description": "Visual JSON cards, workflows, files, and AI search system.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @yadraw/web",
    "dev:web": "npm run dev --workspace @yadraw/web",
    "dev:api": "npm run dev --workspace @yadraw/api",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "infra:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker/docker-compose.yml down"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
