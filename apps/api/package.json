{
  "name": "@yadraw/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:postgres": "node scripts/require-postgres-test-env.mjs && vitest run src/repository.postgres.test.ts src/v2/repository.postgres.test.ts",
    "typecheck": "tsc --noEmit",
    "v2:migrate": "tsx src/v2/migrate-v1-to-v2.ts",
    "v2:verify": "tsx src/v2/verify-v2-migration.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.1.0",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1",
    "zod": "^3.24.1",
    "@yadraw/shared": "file:../../packages/shared"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
